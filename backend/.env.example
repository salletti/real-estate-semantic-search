# Copy this file to ../.env at the project root and fill in real values.

# PostgreSQL
POSTGRES_USER=playiad
POSTGRES_PASSWORD=changeme
POSTGRES_DB=playiad_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async URL consumed by SQLAlchemy + Alembic
DATABASE_URL=postgresql+asyncpg://playiad:changeme@postgres:5432/playiad_db

# Qdrant — local/Docker (default)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=properties

# Qdrant Cloud — set these two to override host/port (production)
# QDRANT_URL=https://YOUR-CLUSTER.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_api_key_here

# App
APP_ENV=development       # development | staging | production
APP_DEBUG=true            # maps to app_debug in core/config.py
SECRET_KEY=generate_with__openssl_rand_hex_32

# CORS — comma-separated list of extra allowed origins (production Vercel URL)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Groq — V4 Gated LLM Intent Parser (https://console.groq.com → API Keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant   # cheap, fast, JSON mode supported
GROQ_TIMEOUT_SECONDS=10.0
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.0
GROQ_SEED=42

# Intent parser — true active le parser hybride rule+LLM (parse_intent_using_llm)
USE_LLM=true

# Search strategy
SEMANTIC_DEFAULT_TOP_K=10
HYBRID_DEFAULT_TOP_K=20
